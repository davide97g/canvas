# ---- Core ----
# Port the Node server listens on (also the port Docker exposes).
PORT=3000
NODE_ENV=production
# Directory for all persistent data (SQLite room DBs, auth DB, app DB, local assets).
# In Docker this is /data (mounted volume).
DATA_DIR=/data

# ---- Auth (Better Auth) ----
# REQUIRED in production. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# The public origin of the app (used for cookies / CSRF).
BETTER_AUTH_URL=https://canvas.davideghiotto.it
# Extra trusted origins, comma-separated (optional).
TRUSTED_ORIGINS=

# Single admin user, seeded at first startup (signups are disabled).
ADMIN_EMAIL=davide@example.com
ADMIN_PASSWORD=change-me-to-a-strong-password

# ---- Assets: Cloudflare R2 (S3-compatible) ----
# If any of these are missing, the server falls back to local-disk asset storage
# (fine for local dev, NOT recommended for production).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=canvas-assets

# ---- tldraw license ----
# Hobby/commercial license key from https://tldraw.dev (leave blank in dev).
# NOTE: this is a build-time (client) variable — it must be present when the
# client bundle is built. Leave undefined in dev; the watermark stays regardless.
VITE_TLDRAW_LICENSE_KEY=
