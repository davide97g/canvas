{
	"name": "canvas",
	"description": "Canvas — self-hostable tldraw whiteboard (Davide Ghiotto).",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"author": {
		"name": "Davide Ghiotto"
	},
	"license": "MIT",
	"main": "./src/server/server.ts",
	"scripts": {
		"dev": "concurrently -n server,client -c red,blue \"npm:dev-server\" \"npm:dev-client\"",
		"dev-server": "tsx watch ./src/server/server.ts",
		"dev-client": "vite dev --host",
		"build": "npm run build-client",
		"build-client": "vite build",
		"generate-logo-variants": "bash scripts/generate-logo-variants.sh",
		"start": "tsx ./src/server/server.ts",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/better-sqlite3": "^7.6.12",
		"@types/node": "^22.10.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^6.0.3",
		"concurrently": "^10.0.3",
		"typescript": "^5.8.3",
		"vite": "^8.1.4"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1086.0",
		"@fastify/cookie": "^11.1.1",
		"@fastify/cors": "^11.3.0",
		"@fastify/rate-limit": "^11.1.0",
		"@fastify/static": "^10.1.0",
		"@fastify/websocket": "^11.3.0",
		"@tldraw/sync": "^5.2.4",
		"@tldraw/sync-core": "^5.2.4",
		"better-auth": "^1.6.23",
		"better-sqlite3": "^12.11.1",
		"fastify": "^5.10.0",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"tldraw": "^5.2.4",
		"tsx": "^4.23.1",
		"unfurl.js": "^6.4.0",
		"ws": "^8.18.0"
	}
}
